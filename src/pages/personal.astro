---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../config/site';
---

<BaseLayout title="Personal" description="Beyond the keyboard.">
  <div class="mx-auto max-w-5xl px-4 py-20">
    <SectionHeading id="personal" eyebrow="Personal" title="Beyond the keyboard" tag="h1" />
    <div class="frost-well reveal max-w-2xl">
      <p class="text-lg leading-relaxed text-[var(--color-body)]">{site.family}</p>
    </div>
    <p class="reveal mono-eyebrow mt-12">// Off the clock</p>
    <div class="mt-4 grid gap-5 sm:grid-cols-2">
      {
        site.hobbies.map((h) => (
          <div class="reveal flex flex-col rounded-lg border border-[var(--color-border)] bg-[rgba(5,18,30,0.6)] p-6 transition-colors hover:border-[var(--color-accent)]">
            <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-[var(--color-accent-sky)]">{h.kicker}</p>
            <h2 class="frost-text mt-2 font-display text-xl font-medium">{h.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-body)]">{h.blurb}</p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {h.tags.map((t) => <li class="hud-chip">{t}</li>)}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>
